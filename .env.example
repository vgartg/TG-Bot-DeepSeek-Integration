# Telegram bot token, obtained from @BotFather
BOT_TOKEN=

# DeepSeek API key, obtained from https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# SQLAlchemy database URL. Default is a local SQLite file.
DATABASE_URL=sqlite:///legal_bot.db

# YooKassa provider token, issued by Telegram for the payment provider
PROVIDER_TOKEN=

# Comma-separated list of Telegram user IDs that get access to the admin panel
ADMIN_IDS=
